PRIVADO_USERNAME=your_privado_email
PRIVADO_PASSWORD=your_privado_password
# Optional. Leave blank to auto-select an available non-maintenance server.
# Server can also be specified as: country code (nl), country name (netherlands),
# country-city format (nl-ams), or server hostname (nl.privadovpn.com)
PRIVADO_SERVER=

# Optional read-only status dashboard
DASHBOARD_ENABLED=false
DASHBOARD_PORT=8080

# Optional tunnel DNS and end-to-end health probe settings
DNS=9.9.9.9,149.112.112.112
HEALTHCHECK_URL=https://api.ipify.org
HEALTHCHECK_TIMEOUT=20
